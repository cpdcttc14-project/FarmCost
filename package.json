{
  "name": "farmcost-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build --base ./",
    "preview": "vite preview --host 127.0.0.1",
    "netlify:build": "npm run build",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:assets": "npx capacitor-assets generate --android --pwa",
    "apk:debug": "npm run cap:sync && cd android && gradlew.bat assembleDebug",
    "apk:release": "npm run cap:sync && cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.3.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "lucide-react": "^0.562.0"
  },
  "devDependencies": {}
}
